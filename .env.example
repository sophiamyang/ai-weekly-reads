MISTRAL_API_KEY=
KINDLE_ENABLED=false
KINDLE_DELIVERY_METHOD=gmail_api
KINDLE_EMAIL=
KINDLE_SENDER_EMAIL=
GMAIL_CREDENTIALS_PATH=config/private/gmail_credentials.json
GMAIL_TOKEN_PATH=config/private/gmail_token.json
# Optional: full contents of gmail_token.json for ephemeral/cloud runs where
# config/private/ does not exist. Takes precedence over the token file.
GMAIL_TOKEN_JSON=
KINDLE_SMTP_HOST=smtp.gmail.com
KINDLE_SMTP_PORT=587
KINDLE_SMTP_USERNAME=
KINDLE_SMTP_PASSWORD=
SUBSTACK_ENABLED=false
SUBSTACK_PUBLICATION_URL=
SUBSTACK_DELIVERY_METHOD=browser_draft
SUBSTACK_AUTO_PUBLISH=false
SUBSTACK_BROWSER_USER_DATA_DIR=config/private/substack/browser
SUBSTACK_COMPOSE_URL=
SUBSTACK_INTRO=
